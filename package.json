{
  "name": "opendocu",
  "version": "1.0.0",
  "description": "Local-first versioned documentation search for coding agents.",
  "type": "module",
  "bin": {
    "opendocu": "./bin/opendocu.mjs"
  },
  "files": [
    "bin/",
    "docs/",
    "scripts/",
    "src/",
    "skills/",
    "tests/",
    ".codex-plugin/",
    ".claude-plugin/",
    "commands/",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "validate:repo": "node scripts/validate_repo.mjs",
    "check": "npm test && npm run validate:repo && node bin/opendocu.mjs --help",
    "gate:real": "node scripts/real_node_gate.mjs",
    "gate:html": "node scripts/real_html_gate.mjs",
    "gate:all": "npm run gate:real && npm run gate:html"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "coding-agent",
    "documentation",
    "search",
    "local-first",
    "codex-plugin",
    "claude-code-plugin"
  ],
  "license": "MIT"
}
